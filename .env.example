# NARA Multi-Miner Environment Variables
# Copy ke .env dan isi sesuai kebutuhan

# Wallet utama (WAJIB)
NARA_MAIN_WALLET=GANTI_DENGAN_WALLET_UTAMA_MU

# RPC endpoint (default: devnet)
NARA_RPC=https://devnet-api.nara.build/

# Relay endpoint (gasless submission)
NARA_RELAY=https://quest-api.nara.build/
